# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://teems:teems@localhost:5432/teems

# ─── Auth ──────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-here

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@toada.com

# ─── Rate Limiting (Upstash Redis) ────────────────────────────
# Optional — login rate limiting degrades gracefully without these
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3003
NODE_ENV=development

# ─── Error Monitoring (Sentry) ────────────────────────────────
# Optional — errors logged to console without this
NEXT_PUBLIC_SENTRY_DSN=
